{
  "name": "the-bridge",
  "version": "1.0.0",
  "description": "Multi-service platform with Different features",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "create-admin": "node scripts/createAdmin.js",
    "setup-postgres": "node scripts/setupPostgreSQL.js",
    "seed-mockup": "node scripts/seedMockupProducts.js",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage"
  },
  "keywords": [
    "smm-panel",
    "freelancing",
    "marketplace",
    "crypto",
    "p2p"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "framer-motion": "^12.23.26",
    "git": "^0.1.5",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "multer": "^1.4.5-lts.1",
    "next-themes": "^0.4.6",
    "node-telegram-bot-api": "^0.63.0",
    "nodemailer": "^7.0.11",
    "openai": "^4.20.1",
    "react-icons": "^5.5.0",
    "socket.io": "^4.5.4",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.22.0",
    "supertest": "^7.1.4"
  }
}
